# ─── General ──────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# ─── Proxy ────────────────────────────────────────────────
PROXY_HOST=0.0.0.0
PROXY_PORT=8000
UPSTREAM_OPENAI_URL=https://api.openai.com
UPSTREAM_ANTHROPIC_URL=https://api.anthropic.com
UPSTREAM_AZURE_OPENAI_URL=https://your-resource.openai.azure.com
DETECTION_SERVICE_URL=http://detection:8001
DETECTION_TIMEOUT_MS=200

# ─── Auth ─────────────────────────────────────────────────
JWKS_URL=https://your-idp.com/.well-known/jwks.json
JWT_ALGORITHM=RS256
JWT_AUDIENCE=ai-governance-firewall
# For dev only — set to "dev-secret" to use HS256 symmetric signing
DEV_JWT_SECRET=dev-secret-change-in-production

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aigw:aigw_password@postgres:5432/ai_governance
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Ollama ───────────────────────────────────────────────
OLLAMA_URL=http://ollama:11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_FALLBACK_MODEL=mistral:7b

# ─── Dashboard ────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_GOVERNANCE_URL=http://localhost:4000
DASHBOARD_PORT=3000

# ─── Governance Service ──────────────────────────────────
GOVERNANCE_PORT=4000
JWT_SECRET=shieldai-dev-secret-change-me
CORS_ORIGIN=http://localhost:3000

# ─── Rate Limits ──────────────────────────────────────────
RATE_LIMIT_USER_RPM=100
RATE_LIMIT_USER_TPM=100000
RATE_LIMIT_DEPT_RPM=1000
RATE_LIMIT_DEPT_TPM=1000000

# ─── Postgres (container env) ────────────────────────────
POSTGRES_USER=aigw
POSTGRES_PASSWORD=aigw_password
POSTGRES_DB=ai_governance
